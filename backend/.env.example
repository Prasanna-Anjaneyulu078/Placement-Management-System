# Copy this file to .env and fill in the real values.
# NEVER commit your actual .env file to version control.

# Generate a secure secret with: openssl rand -hex 32
JWT_SECRET=replace_with_a_strong_random_secret_at_least_256_bits

# Database credentials
DB_URL=jdbc:mysql://localhost:3306/vvit_placement_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=user
DB_PASSWORD=password
